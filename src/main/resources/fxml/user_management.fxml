<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sikerma.sikerma.controller.UserManagementController"
            style="-fx-background-color: #f8fafc;">

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent; -fx-border-width: 0;">
            <VBox spacing="20" style="-fx-padding: 20 30 20 30; -fx-background-color: #f8fafc;">

                <!-- Header -->
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <VBox spacing="3">
                        <Label text="Manajemen Pengguna" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                        <Label text="Kelola akun pengguna sistem SIKERMA"
                               style="-fx-font-size: 12px; -fx-text-fill: #64748b;" wrapText="true"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnTambahUser" text="+ Tambah User" onAction="#handleTambahUser"
                            style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand; -fx-font-size: 12px;"/>
                </HBox>

                <!-- FORM PANEL -->
                <VBox fx:id="formPanel" spacing="15" visible="false" managed="false"
                      style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2); -fx-padding: 20;">

                    <!-- Form Header -->
                    <Label text="Tambah User Baru" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>

                    <!-- Form Fields - 2 kolom -->
                    <GridPane hgap="20" vgap="12">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                        </columnConstraints>

                        <!-- Row 1: Nama Lengkap & Email -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Nama Lengkap *" style="-fx-font-size: 11px; -fx-text-fill: #334155;"/>
                            <TextField fx:id="txtNamaLengkap" promptText="Masukkan nama lengkap"
                                       style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 12; -fx-font-size: 11px;"/>
                        </VBox>

                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Email *" style="-fx-font-size: 11px; -fx-text-fill: #334155;"/>
                            <TextField fx:id="txtEmail" promptText="Masukkan email"
                                       style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 12; -fx-font-size: 11px;"/>
                        </VBox>

                        <!-- Row 2: Username & Password -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Username *" style="-fx-font-size: 11px; -fx-text-fill: #334155;"/>
                            <TextField fx:id="txtUsername" promptText="Masukkan username"
                                       style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 12; -fx-font-size: 11px;"/>
                        </VBox>

                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="Password *" style="-fx-font-size: 11px; -fx-text-fill: #334155;"/>
                            <PasswordField fx:id="txtPassword" promptText="Masukkan password"
                                           style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 12; -fx-font-size: 11px;"/>
                        </VBox>

                        <!-- Row 3: Role (full width) -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="2">
                            <Label text="Role *" style="-fx-font-size: 11px; -fx-text-fill: #334155;"/>
                            <ComboBox fx:id="cbRole" promptText="Pilih role"
                                      style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 12; -fx-font-size: 11px;"/>
                        </VBox>

                    </GridPane>

                    <!-- Action Buttons -->
                    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding-top: 10;">
                        <Button text="Batal" onAction="#handleBatalForm"
                                style="-fx-background-color: white; -fx-text-fill: #475569; -fx-border-color: #e2e8f0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 20; -fx-cursor: hand; -fx-font-size: 11px;"/>
                        <Button text="Simpan User" onAction="#handleSaveUser"
                                style="-fx-background-color: #0d9488; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 20; -fx-cursor: hand; -fx-font-size: 11px;"/>
                    </HBox>

                </VBox>

                <!-- Table Card -->
                <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2); -fx-padding: 20;">

                    <HBox alignment="CENTER_LEFT">
                        <Label text="Daftar Pengguna" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblTotalUsers" text="Total : 0" style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                    </HBox>

                    <TableView fx:id="tableUsers" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: transparent; -fx-border-width: 0; -fx-table-cell-border-color: #e2e8f0;">
                        <columns>
                            <TableColumn fx:id="colUsername" text="Username" prefWidth="100"/>
                            <TableColumn fx:id="colEmail" text="Email" prefWidth="180"/>
                            <TableColumn fx:id="colNamaLengkap" text="Nama Lengkap" prefWidth="180"/>
                            <TableColumn fx:id="colRole" text="Role" prefWidth="100"/>
                            <TableColumn fx:id="colStatus" text="Status" prefWidth="80"/>
                            <TableColumn fx:id="colDibuat" text="Dibuat" prefWidth="100"/>
                            <TableColumn fx:id="colAksi" text="Aksi" prefWidth="80"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>

                </VBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>