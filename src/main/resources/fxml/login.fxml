<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15" style="-fx-background-color: #F3F4F6; -fx-padding: 30;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sikerma.sikerma.controller.LoginController">
    <!-- Judul -->
    <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Login SIKERMA" />

    <!-- Input Username -->
    <TextField fx:id="txtUsername" prefWidth="300" promptText="Username" />

    <!-- Input Password -->
    <PasswordField fx:id="txtPassword" prefWidth="300" promptText="Password" />

    <!-- Tombol Login -->
    <Button onAction="#handleLogin" style="-fx-background-color: #3B82F6; -fx-text-fill: white; -fx-font-weight: bold;" text="LOGIN" />

    <!-- Pesan Error (Awalnya Kosong) -->
    <Label fx:id="lblMessage" style="-fx-text-fill: red; -fx-font-size: 12px;" />
</VBox>