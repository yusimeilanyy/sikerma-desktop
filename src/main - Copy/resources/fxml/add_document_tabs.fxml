<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sikerma.sikerma.controller.AddDocumentTabsController"
            style="-fx-background-color: #f8fafc;">

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-width: 0;">
            <VBox spacing="20" style="-fx-padding: 30 40 40 40; -fx-background-color: #f8fafc;">

                <!-- Header -->
                <VBox spacing="8">
                    <Label text="Tambah Dokumen" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                    <Label text="Lengkapi data dokumen kerja sama di bawah ini"
                           style="-fx-font-size: 14px; -fx-text-fill: #64748b;" wrapText="true"/>
                </VBox>

                <!-- Tab Selector -->
                <HBox spacing="0" style="-fx-background-color: #f1f5f9; -fx-background-radius: 10; -fx-padding: 4;">
                    <Button fx:id="btnTabPemda" text="🏛 Pemerintah Daerah" onAction="#showPemdaTab"
                            style="-fx-background-color: #0d9488; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 12 30; -fx-cursor: hand;"/>
                    <Button fx:id="btnTabNonPemda" text="🏢 Non-Pemerintah Daerah" onAction="#showNonPemdaTab"
                            style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 12 30; -fx-cursor: hand;"/>
                </HBox>

                <!-- PEMDA FORM -->
                <VBox fx:id="boxPemda" spacing="20" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2); -fx-padding: 24;">
                    <GridPane hgap="20" vgap="18">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <!-- Row 1 -->
                        <Label text="Jenis Perjanjian" GridPane.columnIndex="0" GridPane.rowIndex="0"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <ComboBox fx:id="cbJenisPerjanjianPemda" GridPane.columnIndex="1" GridPane.rowIndex="0"
                                  promptText="Pilih jenis perjanjian"
                                  style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8;"/>

                        <!-- Row 2 -->
                        <Label text="Tingkat Kerja Sama" GridPane.columnIndex="0" GridPane.rowIndex="1"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <ComboBox fx:id="cbTingkatKerjaSamaPemda" GridPane.columnIndex="1" GridPane.rowIndex="1"
                                  promptText="Pilih tingkat"
                                  style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8;"/>

                        <!-- Row 3 - Provinsi -->
                        <Label text="Provinsi" GridPane.columnIndex="0" GridPane.rowIndex="2"
                               fx:id="lblProvinsiPemda"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"
                               visible="false" managed="false"/>
                        <VBox fx:id="boxProvinsiPemda" GridPane.columnIndex="1" GridPane.rowIndex="2"
                              visible="false" managed="false">
                            <ComboBox fx:id="cbProvinsiPemda"
                                      promptText="Pilih Provinsi"
                                      style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8;"/>
                        </VBox>

                        <!-- Row 4 - Kabupaten/Kota -->
                        <Label text="Kabupaten/Kota" GridPane.columnIndex="0" GridPane.rowIndex="3"
                               fx:id="lblKabKotaPemda"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"
                               visible="false" managed="false"/>
                        <VBox fx:id="boxKabKotaPemda" GridPane.columnIndex="1" GridPane.rowIndex="3"
                              visible="false" managed="false">
                            <ComboBox fx:id="cbKabKotaPemda"
                                      promptText="Pilih Kabupaten/Kota"
                                      style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8;"/>
                        </VBox>

                        <!-- Row 5 -->
                        <Label text="Jenis Dokumen" GridPane.columnIndex="0" GridPane.rowIndex="4"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <ComboBox fx:id="cbJenisDokumenPemda" GridPane.columnIndex="1" GridPane.rowIndex="4"
                                  promptText="Pilih jenis dokumen"
                                  style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8;"/>

                        <!-- Row 6 - Jenis Dokumen Lainnya -->
                        <Label text="Jenis Dokumen Lainnya" GridPane.columnIndex="0" GridPane.rowIndex="5"
                               fx:id="lblJenisDokumenLainnyaPemda"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"
                               visible="false" managed="false"/>
                        <VBox fx:id="boxJenisDokumenLainnyaPemda" GridPane.columnIndex="1" GridPane.rowIndex="5"
                              visible="false" managed="false">
                            <TextField fx:id="txtJenisDokumenLainnyaPemda"
                                       promptText="Masukkan jenis dokumen lainnya"
                                       style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;"/>
                        </VBox>

                        <!-- Row 7 -->
                        <Label text="PIC BLSDM Komdigi Manado" GridPane.columnIndex="0" GridPane.rowIndex="6"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <ComboBox fx:id="cbPICBlsdmPemda" GridPane.columnIndex="1" GridPane.rowIndex="6"
                                  promptText="Pilih PIC"
                                  style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8;"/>

                        <!-- Row 8 -->
                        <Label text="Nomor Dokumen Balai" GridPane.columnIndex="0" GridPane.rowIndex="7"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <TextField fx:id="txtNomorDokumenBalaiPemda" GridPane.columnIndex="1" GridPane.rowIndex="7"
                                   promptText="Masukkan nomor dokumen balai"
                                   style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;"/>

                        <!-- Row 9 -->
                        <Label text="Nomor Dokumen Pemda" GridPane.columnIndex="0" GridPane.rowIndex="8"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <TextField fx:id="txtNomorDokumenPemda" GridPane.columnIndex="1" GridPane.rowIndex="8"
                                   promptText="Masukkan nomor dokumen pemerintah daerah"
                                   style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;"/>

                        <!-- Row 10 -->
                        <Label text="PIC Pemerintah Daerah" GridPane.columnIndex="0" GridPane.rowIndex="9"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <TextField fx:id="txtPICPemda" GridPane.columnIndex="1" GridPane.rowIndex="9"
                                   promptText="Masukkan nama PIC"
                                   style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;"/>

                        <!-- Row 11 -->
                        <Label text="Kontak PIC" GridPane.columnIndex="0" GridPane.rowIndex="10"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <TextField fx:id="txtKontakPICPemda" GridPane.columnIndex="1" GridPane.rowIndex="10"
                                   promptText="Email atau Nomor Telepon"
                                   style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;"/>

                        <!-- Row 12 -->
                        <Label text="Status" GridPane.columnIndex="0" GridPane.rowIndex="11"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <ComboBox fx:id="cbStatusPemda" GridPane.columnIndex="1" GridPane.rowIndex="11"
                                  style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8;"/>

                        <!-- Row 13 -->
                        <Label text="Tanggal Mulai" GridPane.columnIndex="0" GridPane.rowIndex="12"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <DatePicker fx:id="dpTanggalMulaiPemda" GridPane.columnIndex="1" GridPane.rowIndex="12"
                                    promptText="Pilih tanggal mulai"
                                    style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;"/>

                        <!-- Row 14 -->
                        <Label text="Tanggal Berakhir" GridPane.columnIndex="0" GridPane.rowIndex="13"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <DatePicker fx:id="dpTanggalBerakhirPemda" GridPane.columnIndex="1" GridPane.rowIndex="13"
                                    promptText="Pilih tanggal berakhir"
                                    style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;"/>

                        <!-- Row 15 - Upload File -->
                        <Label text="Dokumen Pendukung" GridPane.columnIndex="0" GridPane.rowIndex="14" GridPane.columnSpan="2"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <VBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="0" GridPane.rowIndex="15" GridPane.columnSpan="2"
                              style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 15;">
                            <Button onAction="#handleChooseFilePemda" text="📎 Pilih file"
                                    style="-fx-background-color: white; -fx-text-fill: #475569; -fx-border-color: #e2e8f0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 16; -fx-font-weight: 600; -fx-cursor: hand;"/>
                            <Label fx:id="lblFileNamePemda" text="Belum ada file dipilih"
                                   style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;"/>
                            <Label text="Format yang didukung: PDF, DOC, DOCX. Maksimal ukuran 10MB."
                                   style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;"/>
                        </VBox>

                        <!-- Row 16 - Catatan -->
                        <Label text="Catatan" GridPane.columnIndex="0" GridPane.rowIndex="16" GridPane.columnSpan="2"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <TextArea fx:id="txtCatatanPemda" GridPane.columnIndex="0" GridPane.rowIndex="17" GridPane.columnSpan="2"
                                  promptText="Masukkan catatan tambahan"
                                  prefRowCount="3"
                                  style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;"/>
                    </GridPane>
                </VBox>

                <!-- NON-PEMDA FORM -->
                <VBox fx:id="boxNonPemda" spacing="20" visible="false" managed="false"
                      style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2); -fx-padding: 24;">
                    <GridPane hgap="20" vgap="18">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <!-- Row 1 -->
                        <Label text="Jenis Perjanjian" GridPane.columnIndex="0" GridPane.rowIndex="0"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <ComboBox fx:id="cbJenisPerjanjianNonPemda" GridPane.columnIndex="1" GridPane.rowIndex="0"
                                  promptText="Pilih jenis perjanjian"
                                  style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8;"/>

                        <!-- Row 2 -->
                        <Label text="Jenis Dokumen" GridPane.columnIndex="0" GridPane.rowIndex="1"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <ComboBox fx:id="cbJenisDokumenNonPemda" GridPane.columnIndex="1" GridPane.rowIndex="1"
                                  promptText="Pilih jenis dokumen"
                                  style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8;"/>

                        <!-- Row 3 - Jenis Dokumen Lainnya -->
                        <Label text="Jenis Dokumen Lainnya" GridPane.columnIndex="0" GridPane.rowIndex="2"
                               fx:id="lblJenisDokumenLainnyaNonPemda"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"
                               visible="false" managed="false"/>
                        <VBox fx:id="boxJenisDokumenLainnyaNonPemda" GridPane.columnIndex="1" GridPane.rowIndex="2"
                              visible="false" managed="false">
                            <TextField fx:id="txtJenisDokumenLainnyaNonPemda"
                                       promptText="Masukkan jenis dokumen lainnya"
                                       style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;"/>
                        </VBox>

                        <!-- Row 4 -->
                        <Label text="Tingkat Kerja Sama / Instansi" GridPane.columnIndex="0" GridPane.rowIndex="3"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <TextField fx:id="txtTingkatKerjaSamaNonPemda" GridPane.columnIndex="1" GridPane.rowIndex="3"
                                   promptText="Contoh: PT Freeport, Harvard University"
                                   style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;"/>

                        <!-- Row 5 -->
                        <Label text="PIC BLSDM Komdigi Manado" GridPane.columnIndex="0" GridPane.rowIndex="4"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <ComboBox fx:id="cbPicBlsdmNonPemda" GridPane.columnIndex="1" GridPane.rowIndex="4"
                                  promptText="Pilih PIC BLSDM Komdigi Manado"
                                  style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8;"/>

                        <!-- Row 6 -->
                        <Label text="Nomor Dokumen Balai" GridPane.columnIndex="0" GridPane.rowIndex="5"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <TextField fx:id="txtNomorDokumenBalaiNonPemda" GridPane.columnIndex="1" GridPane.rowIndex="5"
                                   promptText="Masukkan nomor dokumen balai"
                                   style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;"/>

                        <!-- Row 7 -->
                        <Label text="Nomor Dokumen Mitra" GridPane.columnIndex="0" GridPane.rowIndex="6"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <TextField fx:id="txtNomorDokumenMitra" GridPane.columnIndex="1" GridPane.rowIndex="6"
                                   promptText="Masukkan nomor dokumen mitra"
                                   style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;"/>

                        <!-- Row 8 -->
                        <Label text="PIC Mitra" GridPane.columnIndex="0" GridPane.rowIndex="7"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <TextField fx:id="txtPicMitra" GridPane.columnIndex="1" GridPane.rowIndex="7"
                                   promptText="Masukkan nama PIC mitra"
                                   style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;"/>

                        <!-- Row 9 -->
                        <Label text="Kontak PIC Mitra" GridPane.columnIndex="0" GridPane.rowIndex="8"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <TextField fx:id="txtKontakMitra" GridPane.columnIndex="1" GridPane.rowIndex="8"
                                   promptText="Email atau Nomor Telepon"
                                   style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;"/>

                        <!-- Row 10 -->
                        <Label text="Status" GridPane.columnIndex="0" GridPane.rowIndex="9"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <ComboBox fx:id="cbStatusNonPemda" GridPane.columnIndex="1" GridPane.rowIndex="9"
                                  style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8;"/>

                        <!-- Row 11 -->
                        <Label text="Tanggal Mulai" GridPane.columnIndex="0" GridPane.rowIndex="10"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <DatePicker fx:id="dpTanggalMulaiNonPemda" GridPane.columnIndex="1" GridPane.rowIndex="10"
                                    promptText="Pilih tanggal mulai"
                                    style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;"/>

                        <!-- Row 12 -->
                        <Label text="Tanggal Berakhir" GridPane.columnIndex="0" GridPane.rowIndex="11"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <DatePicker fx:id="dpTanggalBerakhirNonPemda" GridPane.columnIndex="1" GridPane.rowIndex="11"
                                    promptText="Pilih tanggal berakhir"
                                    style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;"/>

                        <!-- Row 13 - Upload File -->
                        <Label text="Dokumen Pendukung" GridPane.columnIndex="0" GridPane.rowIndex="12" GridPane.columnSpan="2"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <VBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="0" GridPane.rowIndex="13" GridPane.columnSpan="2"
                              style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 15;">
                            <Button onAction="#handleChooseFileNonPemda" text="📎 Pilih file"
                                    style="-fx-background-color: white; -fx-text-fill: #475569; -fx-border-color: #e2e8f0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 16; -fx-font-weight: 600; -fx-cursor: hand;"/>
                            <Label fx:id="lblFileNameNonPemda" text="Belum ada file dipilih"
                                   style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;"/>
                            <Label text="Format yang didukung: PDF, DOC, DOCX. Maksimal ukuran 10MB."
                                   style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;"/>
                        </VBox>

                        <!-- Row 14 - Catatan -->
                        <Label text="Catatan" GridPane.columnIndex="0" GridPane.rowIndex="14" GridPane.columnSpan="2"
                               style="-fx-font-weight: 600; -fx-text-fill: #334155; -fx-font-size: 13px;"/>
                        <TextArea fx:id="txtCatatanNonPemda" GridPane.columnIndex="0" GridPane.rowIndex="15" GridPane.columnSpan="2"
                                  promptText="Masukkan catatan tambahan"
                                  prefRowCount="3"
                                  style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;"/>
                    </GridPane>
                </VBox>

                <!-- Buttons -->
                <HBox spacing="12" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
                    <Button text=" Batal" onAction="#handleCancel"
                            style="-fx-background-color: white; -fx-text-fill: #64748b; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 24; -fx-font-weight: 600; -fx-cursor: hand;"/>
                    <Button text="💾 Simpan Dokumen" onAction="#handleSave"
                            style="-fx-background-color: #0d9488; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 24; -fx-font-weight: 600; -fx-cursor: hand;"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>