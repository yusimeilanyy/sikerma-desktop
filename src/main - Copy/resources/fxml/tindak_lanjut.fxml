<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.sikerma.sikerma.controller.TindakLanjutController"
      spacing="20" style="-fx-padding: 30 40 40 40; -fx-background-color: #f8fafc;">

    <!-- Header -->
    <VBox spacing="8">
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label text="Dokumen Kadaluarsa" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
        </HBox>
        <Label text="Daftar dokumen yang telah melewati tanggal berakhir dan membutuhkan perpanjangan."
               style="-fx-font-size: 14px; -fx-text-fill: #64748b;" wrapText="true"/>
    </VBox>

    <!-- Search -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <TextField fx:id="txtSearch" promptText="Cari dokumen, mitra, atau nomor..."
                   style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-padding: 10 15; -fx-pref-width: 350;"/>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- Content Area -->
    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <!-- Table -->
        <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2); -fx-padding: 20;"
              HBox.hgrow="ALWAYS">
            <TableView fx:id="tableDokumen" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: transparent; -fx-border-width: 0; -fx-hbar-policy: NEVER; -fx-vbar-policy: NEVER;">
                <columns>
                    <TableColumn fx:id="colNo" text="No" prefWidth="50" resizable="false"/>
                    <TableColumn fx:id="colJenis" text="Jenis" prefWidth="80" resizable="false"/>
                    <TableColumn fx:id="colNomorDokumen" text="Nomor Dokumen" prefWidth="150" resizable="false"/>
                    <TableColumn fx:id="colMitra" text="Mitra" prefWidth="180" resizable="false"/>
                    <TableColumn fx:id="colTanggalBerakhir" text="Tanggal Berakhir" prefWidth="150" resizable="false"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="120" resizable="false"/>
                    <TableColumn fx:id="colAksi" text="Aksi" prefWidth="165" resizable="false"/>
                </columns>
            </TableView>

            <!-- Pagination -->
            <HBox alignment="CENTER" spacing="15" style="-fx-padding: 15 0 0 0;">
                <Label fx:id="lblPageInfo" style="-fx-font-size: 13px; -fx-text-fill: #64748b;" text="Menampilkan 1 - 10 dari 10 dokumen"/>
                <HBox spacing="5" alignment="CENTER">
                    <Button fx:id="btnPrevPage" text="&lt;" style="-fx-background-color: #f1f5f9; -fx-text-fill: #94a3b8; -fx-background-radius: 8; -fx-padding: 8 12; -fx-cursor: hand;" onAction="#handlePrevPage"/>
                    <Button fx:id="btnPage1" text="1" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 14; -fx-cursor: hand;" onAction="#handlePageClick"/>
                    <Button fx:id="btnPage2" text="2" style="-fx-background-color: #f1f5f9; -fx-text-fill: #64748b; -fx-background-radius: 8; -fx-padding: 8 14; -fx-cursor: hand;" onAction="#handlePageClick"/>
                    <Button fx:id="btnPage3" text="3" style="-fx-background-color: #f1f5f9; -fx-text-fill: #64748b; -fx-background-radius: 8; -fx-padding: 8 14; -fx-cursor: hand;" onAction="#handlePageClick"/>
                    <Button fx:id="btnNextPage" text="&gt;" style="-fx-background-color: #f1f5f9; -fx-text-fill: #94a3b8; -fx-background-radius: 8; -fx-padding: 8 12; -fx-cursor: hand;" onAction="#handleNextPage"/>
                </HBox>
            </HBox>
        </VBox>

        <!-- Detail Panel -->
        <VBox fx:id="detailPanel" spacing="20" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2); -fx-padding: 25; -fx-pref-width: 400;" visible="false" managed="false">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Detail Dokumen" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnCloseDetail" text="×" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-font-size: 20px; -fx-cursor: hand;" onAction="#closeDetailPanel"/>
            </HBox>

            <Separator/>

            <!-- Document Info -->
            <VBox spacing="12">
                <Label text="Informasi Dokumen" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <GridPane vgap="10" hgap="10">
                    <columnConstraints>
                        <ColumnConstraints hgrow="NEVER" prefWidth="120"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>

                    <Label text="Jenis" style="-fx-text-fill: #64748b; -fx-font-size: 12px;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label fx:id="lblDetailJenis" text="-" style="-fx-text-fill: #1e293b; -fx-font-weight: bold; -fx-font-size: 12px;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="Nomor Dokumen" style="-fx-text-fill: #64748b; -fx-font-size: 12px;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="lblDetailNomor" text="-" style="-fx-text-fill: #1e293b; -fx-font-weight: bold; -fx-font-size: 12px;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Mitra" style="-fx-text-fill: #64748b; -fx-font-size: 12px;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Label fx:id="lblDetailMitra" text="-" style="-fx-text-fill: #1e293b; -fx-font-weight: bold; -fx-font-size: 12px;" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <Label text="Tanggal Mulai" style="-fx-text-fill: #64748b; -fx-font-size: 12px;" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <Label fx:id="lblDetailTanggalMulai" text="-" style="-fx-text-fill: #1e293b; -fx-font-weight: bold; -fx-font-size: 12px;" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <Label text="Tanggal Berakhir" style="-fx-text-fill: #64748b; -fx-font-size: 12px;" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <Label fx:id="lblDetailTanggalBerakhir" text="-" style="-fx-text-fill: #dc2626; -fx-font-weight: bold; -fx-font-size: 12px;" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                    <Label text="Status" style="-fx-text-fill: #64748b; -fx-font-size: 12px;" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                    <Label fx:id="lblDetailStatus" text="Kadaluarsa" style="-fx-text-fill: #dc2626; -fx-font-weight: bold; -fx-font-size: 12px;" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                </GridPane>
            </VBox>

            <Separator/>

            <!-- Extension Form -->
            <VBox spacing="12">
                <Label text="Perpanjangan" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>

                <VBox spacing="6">
                    <Label text="Tanggal Berakhir Baru *" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <DatePicker fx:id="dpTanggalBaru" promptText="Pilih tanggal..."
                                style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 8;"/>
                </VBox>

                <Label text="⚠️ Status dokumen akan diperbarui otomatis menjadi 'Aktif' setelah proses perpanjangan berhasil diselesaikan."
                       wrapText="true"
                       style="-fx-background-color: #fef3c7; -fx-border-color: #fde68a; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12; -fx-text-fill: #92400e; -fx-font-size: 11px;"/>

                <VBox spacing="6">
                    <Label text="Catatan (Opsional)" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextArea fx:id="txtCatatan" prefRowCount="3" promptText="Contoh: Perpanjangan sesuai hasil evaluasi tahun 2026"
                              style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 8;"/>
                </VBox>

                <Button fx:id="btnPerpanjang" text="🔄 Perpanjang Dokumen" maxWidth="Infinity"
                        style="-fx-background-color: #14b8a6; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 12; -fx-font-weight: bold; -fx-cursor: hand;"
                        onAction="#handlePerpanjang"/>
            </VBox>

            <Separator/>

            <!-- Extension History -->
            <VBox spacing="12" VBox.vgrow="ALWAYS">
                <Label text="Riwayat Perpanjangan" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>

                <ScrollPane fx:id="scrollRiwayat" style="-fx-background-color: transparent; -fx-border-width: 0;" VBox.vgrow="ALWAYS" fitToWidth="true">
                    <VBox fx:id="riwayatContainer" spacing="12" style="-fx-padding: 5;"/>
                </ScrollPane>
            </VBox>
        </VBox>
    </HBox>
</VBox>